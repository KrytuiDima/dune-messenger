{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dune-messenger",
  "version": "0.1.0",
  "identifier": "com.dune.messenger",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Dune Messenger",
        "width": 1000,
        "height": 650,
        "minWidth": 760,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}